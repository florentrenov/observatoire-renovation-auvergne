    "site:shell:check": "node scripts/site-shell.mjs --check",
    "site:shell:write": "node scripts/site-shell.mjs --write",
    "site:seo:check": "node scripts/site-metadata.mjs --check",
    "site:seo:write": "node scripts/site-metadata.mjs --write",
    "site:projects:quality": "node scripts/project-quality.mjs",
    "site:relations": "node scripts/build-relations.mjs",
    "site:veille:test": "node scripts/veille-contract.test.mjs",
